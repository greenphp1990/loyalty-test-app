# =========================================================================
# Loyalty Test - Environment Variables Template
# Copy this file to '.env' and fill in the values for local development.
# =========================================================================

# Database Connection (PostgreSQL)
# For local development: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For Cloud (Neon/Supabase): postgresql://...
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/loyalty_test?schema=public"

# Application Settings
NEXT_PUBLIC_APP_NAME="Loyalty Test"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="NGN"
JWT_SECRET="replace-with-a-very-strong-secure-random-secret-key-32-chars"

# Payment Gateways (Paystack & Flutterwave)
# Sandbox credentials can be obtained from your gateway developer dashboard
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_HASH_SECRET="flutterwave-webhook-secret-hash"

# Messaging (SMS API Provider)
# Set your API details for Twilio or a local SMS provider (e.g., Termii)
SMS_API_KEY="your-sms-api-key"
SMS_PROVIDER="mock" # mock, termii, twilio, bulksmsnigeria
SMS_SENDER_ID="LOYALTYTEST"

# BulkSMSNigeria SMS API Configuration
BULKSMS_NIGERIA_BASE_URL="https://www.bulksmsnigeria.com/api/v2"
BULKSMS_NIGERIA_API_TOKEN=""
BULKSMS_NIGERIA_SENDER_ID="LOYALTY"
BULKSMS_NIGERIA_GATEWAY="direct-refund"
BULKSMS_NIGERIA_APPEND_SENDER="hosted"
BULKSMS_NIGERIA_CALLBACK_URL=""

# WhatsApp Business / Share Configuration
WHATSAPP_API_URL="https://graph.facebook.com/v20.0"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_RECIPIENT_OVERRIDE="" # Empty in production; set to your own number for local testing

# Brevo WhatsApp Configuration
WHATSAPP_PROVIDER="mock" # "mock" or "wasenderapi" or "brevo"
BREVO_API_KEY=""
BREVO_WHATSAPP_BASE_URL="https://api.brevo.com/v3"
BREVO_WHATSAPP_TEMPLATE_ID=""
BREVO_WHATSAPP_SENDER_NUMBER=""

# WasenderAPI WhatsApp Configuration
WASENDER_API_BASE_URL="https://www.wasenderapi.com"
WASENDER_API_KEY=""

